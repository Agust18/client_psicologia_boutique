---
// Footer component - Single Responsibility: Footer display
---

<footer class="w-full py-12 md:py-16 px-6 mt-auto bg-slate-50 dark:bg-slate-950 border-t border-slate-200 dark:border-slate-900" aria-labelledby="footer-heading">
    <h2 id="footer-heading" class="sr-only">Footer</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 max-w-7xl mx-auto">
        <div class="md:col-span-1">
            <div class="text-xl font-serif italic text-slate-900 dark:text-slate-100 mb-4">
                Atelier Medical
            </div>
            <p class="font-sans text-sm text-slate-700 dark:text-slate-400 leading-relaxed">
                Consultoría médica boutique dedicada a la excelencia en casos de
                alta complejidad interdisciplinaria.
            </p>
        </div>

        <nav aria-label="Navegación del pie de página">
            <h3 class="font-serif italic text-slate-900 dark:text-slate-100 mb-5 text-base font-bold">
                Navegación
            </h3>
            <ul class="space-y-2">
                {['Inicio', 'Sobre Nosotros', 'Equipo Médico', 'Filosofía'].map((item) => (
                    <li>
                        <a href={`#${item.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-')}`} 
                           class="font-sans text-sm text-slate-700 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors underline-offset-4 hover:underline py-2 inline-block w-full md:w-auto">
                            {item}
                        </a>
                    </li>
                ))}
            </ul>
        </nav>

        <nav aria-label="Servicios">
            <h3 class="font-serif italic text-slate-900 dark:text-slate-100 mb-5 text-base font-bold">
                Servicios
            </h3>
            <ul class="space-y-2">
                <li><a href="#areas-intervencion" class="font-sans text-sm text-slate-700 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors py-2 inline-block w-full md:w-auto">Áreas de Intervención</a></li>
                <li><a href="#psicologia-organizacional" class="font-sans text-sm text-slate-700 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors py-2 inline-block w-full md:w-auto">Psicología Organizacional</a></li>
                <li><a href="#contacto" class="font-sans text-sm text-slate-700 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors py-2 inline-block font-medium w-full md:w-auto">Contacto</a></li>
            </ul>
        </nav>

        <div>
            <h3 class="font-serif italic text-slate-900 dark:text-slate-100 mb-5 text-base font-bold">
                Legal
            </h3>
            <ul class="space-y-2">
                <li><a href="/privacidad" class="font-sans text-sm text-slate-700 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors py-2 inline-block w-full md:w-auto">Política de Privacidad</a></li>
                <li><a href="/terminos" class="font-sans text-sm text-slate-700 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors py-2 inline-block w-full md:w-auto">Términos de Servicio</a></li>
            </ul>
        </div>
    </div>

    <div class="max-w-7xl mx-auto border-t border-slate-200 dark:border-slate-800 mt-12 pt-8 text-center md:text-left">
        <p class="font-sans text-xs md:text-sm text-slate-500 dark:text-slate-500">
            © {new Date().getFullYear()} Atelier Medical. Todos los derechos reservados. <br class="md:hidden" /> Credenciales verificadas.
        </p>
    </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Add smooth scrolling to footer links
    document.querySelectorAll('footer a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e: Event) => {
        if (!(e.target instanceof Node)) return;
        e.preventDefault();
        const currentAnchor = e.currentTarget;
        if (!(currentAnchor instanceof HTMLAnchorElement)) return;
        const href = currentAnchor.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });
  });
</script>
