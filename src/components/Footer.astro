---
// Footer component - Single Responsibility: Footer display
---

<footer class="w-full py-8 md:py-16 px-4 md:px-6 mt-auto bg-slate-50 dark:bg-slate-950 border-t border-slate-200 dark:border-slate-900">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-7xl mx-auto">
        <div class="md:col-span-1">
            <div class="text-lg font-serif italic text-slate-900 dark:text-slate-100 mb-4">
                Atelier Medical
            </div>
            <p class="font-sans text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                Consultoría médica boutique dedicada a la excelencia en casos de
                alta complejidad interdisciplinaria.
            </p>
        </div>

        <div>
            <h3 class="font-serif italic text-slate-900 dark:text-slate-100 mb-4 text-base">
                Navegación
            </h3>
            <ul class="space-y-3">
                {['Inicio', 'Sobre Nosotros', 'Equipo Médico', 'Filosofía'].map((item) => (
                    <li>
                        <a href={`#${item.toLowerCase().replace(' ', '-')}`} 
                           class="font-sans text-sm text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors underline-offset-4 hover:underline">
                            {item}
                        </a>
                    </li>
                ))}
            </ul>
        </div>

        <div>
            <h3 class="font-serif italic text-slate-900 dark:text-slate-100 mb-4 text-base">
                Servicios
            </h3>
            <ul class="space-y-3">
                <li><a href="#areas-intervencion" class="font-sans text-sm text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors">Áreas de Intervención</a></li>
                <li><a href="#psicologia-organizacional" class="font-sans text-sm text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors">Psicología Organizacional</a></li>
                <li><a href="#contacto" class="font-sans text-sm text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors">Contacto</a></li>
            </ul>
        </div>

        <div>
            <h3 class="font-serif italic text-slate-900 dark:text-slate-100 mb-4 text-base">
                Legal
            </h3>
            <ul class="space-y-3">
                <li><a href="#" class="font-sans text-sm text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors">Política de Privacidad</a></li>
                <li><a href="#" class="font-sans text-sm text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors">Términos de Servicio</a></li>
            </ul>
        </div>
    </div>

    <div class="max-w-7xl mx-auto border-t border-slate-200 dark:border-slate-800 mt-10 pt-6 text-center md:text-left">
        <p class="font-sans text-xs md:text-sm text-slate-500 dark:text-slate-500">
            © {new Date().getFullYear()} Atelier Medical. Todos los derechos reservados. <br class="md:hidden" /> Credenciales verificadas.
        </p>
    </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Add smooth scrolling to footer links
    document.querySelectorAll('footer a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e: Event) => {
        if (!(e.target instanceof Node)) return;
        e.preventDefault();
        const currentAnchor = e.currentTarget;
        if (!(currentAnchor instanceof HTMLAnchorElement)) return;
        const href = currentAnchor.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });
  });
</script>
