---
import { Image } from "astro:assets";
import AltoRen from "../assets/images/psicologia-alto-rendimiento.jpg";
// OrganizationalPsychologySection component - Single Responsibility: Organizational psychology display
const { id } = Astro.props;
---

<section id={id} class="py-24 md:py-32 px-4 md:px-8 bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto bg-primary-container rounded-3xl overflow-hidden shadow-2xl flex flex-col lg:flex-row border border-white/10">
    
    <div class="lg:w-1/2 p-8 md:p-12 lg:p-20 flex flex-col justify-center">
      <span class="font-label text-xs md:text-sm uppercase tracking-widest text-tertiary-fixed-dim block mb-6 font-bold">
        Corporativo & Organizacional
      </span>
      
      <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl text-white mb-8 leading-tight">
        Psicología para <span class="italic text-tertiary-fixed-dim">Organizaciones de Alto Rendimiento.</span>
      </h2>
      
      <p class="text-slate-200 text-lg mb-10 leading-relaxed font-body">
        Trasladamos nuestra experiencia clínica a la salud sistémica de las empresas. Resolvemos conflictos, potenciamos el liderazgo y cuidamos el capital humano.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="text-white flex items-center gap-3 group">
          <span class="material-symbols-outlined text-tertiary-fixed-dim bg-white/10 p-2 rounded-lg" aria-hidden="true">rocket_launch</span>
          <span class="font-medium">Coaching Ejecutivo</span>
        </div>
        <div class="text-white flex items-center gap-3 group">
          <span class="material-symbols-outlined text-tertiary-fixed-dim bg-white/10 p-2 rounded-lg" aria-hidden="true">diversity_3</span>
          <span class="font-medium">Equipos dinámicos</span>
        </div>
        <div class="text-white flex items-center gap-3 group">
          <span class="material-symbols-outlined text-tertiary-fixed-dim bg-white/10 p-2 rounded-lg" aria-hidden="true">forum</span>
          <span class="font-medium">Resolución de Conflictos</span>
        </div>
        <div class="text-white flex items-center gap-3 group">
          <span class="material-symbols-outlined text-tertiary-fixed-dim bg-white/10 p-2 rounded-lg" aria-hidden="true">sync_alt</span>
          <span class="font-medium">Feedback 360</span>
        </div>
      </div>
    </div>

    <div class="lg:w-1/2 relative min-h-[300px] md:min-h-[400px]">
      <Image 
        src={AltoRen} 
        alt="Equipo profesional en entorno de oficina moderna de alto rendimiento" 
        class="absolute inset-0 w-full h-full object-cover opacity-60"
        loading="lazy"
        decoding="async"
        width={1200}
        height={800}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-container via-transparent to-transparent hidden lg:block"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>

  </div>
</section>