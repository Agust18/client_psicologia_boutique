---
import { equipo } from "./Team/data/equipo";
import type { Profesional } from "./Team/data/equipo";
import TarjetaEspecialista from "./Team/TarjetaEspecialista.astro";
import BotonModal from "./Team/BotonModal.astro";
import ModalPerfil from "./Team/ModalPerfil.astro";

import fotoDemian from "../assets/images/leadership.jpg";
import fotoSebastian from "../assets/images/leadership2.jpg";
import fotoDiego from "../assets/images/leadership3.jpg";

const fotos = {
  demian: fotoDemian,
  sebastian: fotoSebastian,
  diego: fotoDiego,
};

const { id } = Astro.props;
---

<section
  id={id}
  class="py-24 md:py-32 px-8 bg-surface-container-low scroll-reveal overflow-hidden"
>
  <div class="max-w-7xl mx-auto text-center mb-16 md:mb-20">
    <h2 class="font-headline text-4xl md:text-5xl text-primary leading-tight">
      Dirección Médica y Clínica
    </h2>
    <div class="h-1 w-24 bg-tertiary-fixed-dim mx-auto mt-6" aria-hidden="true"></div>
  </div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
    {equipo.map((p) => (
      <article class="group text-center md:text-left card-especialista">
        <TarjetaEspecialista
          profesional={p}
          foto={fotos[p.id as keyof typeof fotos]}
        />
        <h3 class="font-headline text-2xl text-primary">{p.nombre}</h3>
        <p class="font-body text-xs text-secondary uppercase tracking-widest mt-2 font-bold">
          {p.titulo}
        </p>
        <BotonModal modalId={`modal-${p.id}`} />
      </article>
    ))}
  </div>


{equipo.map((p: Profesional) => (
  <ModalPerfil
    {...p}
    foto={fotos[p.id as keyof typeof fotos]}
    
  />
))}
</section>

<script>
  document.querySelectorAll('.modal-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const modalId = (btn as HTMLElement).dataset.modal;
      const modal = document.getElementById(modalId!);
      if (modal) {
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
    });
  });
</script>