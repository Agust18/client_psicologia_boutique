---
// AreasInterventionSection component - Single Responsibility: Areas display
const { id } = Astro.props;
const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 -960 960 960" fill="currentColor"><path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm158-440-203 203-109-109-57 57 166 166 260-260-57-57Z"/></svg>`;
---

<section id={id} class="py-24 md:py-32 px-8 bg-surface">
  <div class="max-w-7xl mx-auto mb-16 md:mb-20">
    <h2 class="font-headline text-4xl text-primary mb-4">
      Áreas de Intervención
    </h2>
    <p class="text-secondary max-w-2xl text-lg">
      Especialidades integradas para una gestión clínica de excelencia.
    </p>
  </div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <article
      class="bg-surface-container-lowest p-10 rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.04)] border-b-4 border-tertiary-fixed-dim hover:-translate-y-2 transition-transform"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="40"
        height="40"
        viewBox="0 -960 960 960"
        fill="currentColor"
        class="text-primary mb-8 block"
        aria-hidden="true"
      >
        <path
          d="M520-80v-163q-106-21-173-105.5T280-552v-248h80v248q0 83 58.5 141.5T560-352q83 0 141.5-58.5T760-552v-248h80v248q0 119-67 203.5T600-243v163h-80ZM320-640q-50 0-85-35t-35-85q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35Zm480 0q-50 0-85-35t-35-85q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35Zm-480-80q17 0 28.5-11.5T360-760q0-17-11.5-28.5T320-800q-17 0-28.5 11.5T280-760q0 17 11.5 28.5T320-720Zm480 0q17 0 28.5-11.5T840-760q0-17-11.5-28.5T800-800q-17 0-28.5 11.5T760-760q0 17 11.5 28.5T800-720Z"
        ></path>
      </svg>
      <h3 class="font-headline text-2xl text-primary mb-4">Medicina Clínica</h3>
      <ul class="space-y-4 text-slate-700 font-body">
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"
            ><Fragment set:html={checkIcon} />
          </span>
          Seguimiento de enfermedades crónicas complejas.
        </li>
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"
            ><Fragment set:html={checkIcon} />
          </span>
          Gestión de estudios diagnósticos avanzados.
        </li>
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"
            ><Fragment set:html={checkIcon} />
          </span>
          Coordinación de interconsultas de especialistas.
        </li>
      </ul>
    </article>

    <article
      class="bg-surface-container-lowest p-10 rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.04)] border-b-4 border-tertiary-fixed-dim hover:-translate-y-2 transition-transform"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="40"
        height="40"
        viewBox="0 -960 960 960"
        fill="currentColor"
        class="text-primary mb-8 block"
        aria-hidden="true"
      >
        <path
          d="M480-80 310-250l57-57 73 73v-286h80v286l73-73 57 57L480-80ZM280-520v-280q0-33 23.5-56.5T360-880h240q33 0 56.5 23.5T680-800v280q0 33-23.5 56.5T600-520H360q-33 0-56.5-23.5T280-520Zm80-80h240v-200H360v200Zm120-40q17 0 28.5-11.5T520-680q0-17-11.5-28.5T480-720q-17 0-28.5 11.5T440-680q0 17 11.5 28.5T480-640Z"
        ></path>
      </svg>
      <h3 class="font-headline text-2xl text-primary mb-4">Psiquiatría</h3>
      <ul class="space-y-4 text-slate-700 font-body">
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"><Fragment set:html={checkIcon} /></span
          >
          Terapia sistémica y estabilización farmacológica.
        </li>
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"><Fragment set:html={checkIcon} /></span
          >
          Visitas domiciliarias para pacientes con movilidad reducida.
        </li>
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"><Fragment set:html={checkIcon} /></span
          >
          Abordaje de cuadros psiquiátricos refractarios.
        </li>
      </ul>
    </article>

    <article
      class="bg-surface-container-lowest p-10 rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.04)] border-b-4 border-tertiary-fixed-dim hover:-translate-y-2 transition-transform"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="40"
        height="40"
        viewBox="0 -960 960 960"
        fill="currentColor"
        class="text-primary mb-8 block"
        aria-hidden="true"
      >
        <path
          d="M480-520q-50 0-85-35t-35-85q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35Zm0-400q-33 0-56.5 23.5T400-840q0 33 23.5 56.5T480-760q33 0 56.5-23.5T560-840q0-33-23.5-56.5T480-920Zm0 840q-101 0-192-38t-158-106l56-56q55 56 127 88t150 32q78 0 150-32t127-88l56 56q-67 68-158 106t-192 38ZM171-423l-57-57q34-34 51.5-79T183-653l80 12q-3 40-19 79t-73 139Zm618 0q-57-100-73-139t-19-79l80-12q3 49 20.5 94T846-480l-57 57Zm-455-14 36-224 130 130 130-130 36 224h94l-50-313-210 210-210-210-50 313h94Z"
        ></path>
      </svg>
      <h3 class="font-headline text-2xl text-primary mb-4">
        Psicología Clínica
      </h3>
      <ul class="space-y-4 text-slate-700 font-body">
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"><Fragment set:html={checkIcon} /></span
          >
          Evaluación neurocognitiva y neuropsicológica.
        </li>
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"><Fragment set:html={checkIcon} /></span
          >
          Intervención en sistemas familiares complejos.
        </li>
        <li class="flex items-start gap-3">
          <span
            class="material-symbols-outlined text-tertiary-fixed-dim text-sm mt-1"
            aria-hidden="true"><Fragment set:html={checkIcon} /></span
          >
          Terapia Cognitivo-Conductual de alta especificidad.
        </li>
      </ul>
    </article>
  </div>
</section>
