---
import { Image } from "astro:assets";
import ReunionFami from "../assets/images/psicologia-organizacional.jpg";
const { id } = Astro.props;
---

<section id={id} class="py-24 md:py-32 px-8 bg-surface-container-low">
  <div class="max-w-7xl mx-auto mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
      <h2 class="font-headline text-4xl text-primary leading-tight text-balance">Intervenciones <br class="md:hidden"/> Destacadas</h2>
      <p class="text-secondary mt-2">Estrategias clínicas diseñadas para momentos críticos.</p>
    </div>
    <a href="#contacto" class="text-primary font-bold border-b border-primary pb-1 flex items-center gap-2 hover:text-secondary hover:border-secondary transition-colors group">
      Consultar abordajes
      <span class="material-symbols-outlined text-sm group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" aria-hidden="true">arrow_outward</span>
    </a>
  </div>

  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-4 h-auto md:h-[600px]">
    
    <article class="md:col-span-2 md:row-span-2 bg-primary-container rounded-3xl p-8 relative overflow-hidden group min-h-[400px]">
       <Image
            src={ReunionFami}
            alt="Sesión de terapia familiar"
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
        />
      <div class="relative z-10 h-full flex flex-col justify-end">
        <h3 class="text-3xl font-headline text-white mb-4">Reuniones Familiares</h3>
        <p class="text-white/90 max-w-sm font-body">Mediación y abordaje de crisis en el núcleo familiar como eje de la recuperación.</p>
      </div>
    </article>

    <a href="#jornadas" class="md:col-span-2 bg-secondary p-8 rounded-3xl flex flex-col justify-between group hover:bg-primary transition-all duration-500 min-h-[250px]">
      <div class="flex justify-between items-start">
        <span class="material-symbols-outlined text-white text-3xl" aria-hidden="true">schedule</span>
        <span class="material-symbols-outlined text-white/50 group-hover:text-white transition-colors" aria-hidden="true">north_east</span>
      </div>
      <div>
        <h3 class="text-2xl font-headline text-white">Jornadas Intensivas</h3>
        <p class="text-slate-100 text-sm mt-2 font-body opacity-80">Abordajes de 48-72hs para desestabilización aguda.</p>
      </div>
    </a>

    <article class="md:col-span-1 bg-tertiary-fixed-dim p-8 rounded-3xl flex flex-col justify-between group min-h-[180px] hover:shadow-lg transition-shadow">
      <span class="material-symbols-outlined text-on-tertiary-fixed text-3xl" aria-hidden="true">flight_takeoff</span>
      <h3 class="text-xl font-headline text-on-tertiary-fixed">Viajes Terapéuticos</h3>
    </article>

    <article class="md:col-span-1 bg-white p-8 rounded-3xl flex flex-col justify-between border border-outline-variant group min-h-[180px] hover:border-primary transition-colors">
      <span class="material-symbols-outlined text-error text-3xl" aria-hidden="true">emergency</span>
      <h3 class="text-xl font-headline text-primary">Intervención en Crisis</h3>
    </article>

  </div>
</section>