---
import { Image } from "astro:assets";
import ReunionFami from "../assets/images/psicologia-organizacional.jpg";
const { id } = Astro.props;
---

<section id={id} class="py-24 md:py-32 px-8 bg-surface-container-low">
  <div
    class="max-w-7xl mx-auto mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6"
  >
    <div>
      <h2
        class="font-headline text-4xl text-primary leading-tight text-balance"
      >
        Intervenciones <br class="md:hidden" /> Destacadas
      </h2>
      <p class="text-secondary mt-2">
        Estrategias clínicas diseñadas para momentos críticos.
      </p>
    </div>
    <a
      href="#contacto"
      class="text-primary font-bold border-b border-primary pb-1 flex items-center gap-2 hover:text-secondary hover:border-secondary transition-colors group"
    >
      Consultar abordajes
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 -960 960 960"
        fill="currentColor"
        class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
        aria-hidden="true"
      >
        <path d="M200-120v-80h457L157-700l56-56 500 500v-457h80v593H200Z"
        ></path>
      </svg>
    </a>
  </div>

  <div
    class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-4 h-auto md:h-[600px]"
  >
    <article
      class="md:col-span-2 md:row-span-2 bg-primary-container rounded-3xl p-8 relative overflow-hidden group min-h-[400px]"
    >
      <Image
        src={ReunionFami}
        alt="Sesión de terapia familiar"
        class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-105 transition-transform duration-700"
        loading="lazy"
        quality="low"
        width={800}
      />
      <div class="relative z-10 h-full flex flex-col justify-end">
        <h3 class="text-3xl font-headline text-white mb-4">
          Reuniones Familiares
        </h3>
        <p class="text-white/90 max-w-sm font-body">
          Mediación y abordaje de crisis en el núcleo familiar como eje de la
          recuperación.
        </p>
      </div>
    </article>

    <a
      href="#jornadas"
      class="md:col-span-2 bg-secondary p-8 rounded-3xl flex flex-col justify-between group hover:bg-primary transition-all duration-500 min-h-[250px]"
    >
      <div class="flex justify-between items-start">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 -960 960 960"
          fill="currentColor"
          class="text-white"
          aria-hidden="true"
        >
          <path
            d="m612-292 56-56-148-148v-184h-80v216l172 172ZM480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Z"
          ></path>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 -960 960 960"
          fill="currentColor"
          class="text-white/50 group-hover:text-white transition-colors"
          aria-hidden="true"
        >
          <path d="M200-120v-80h457L157-700l56-56 500 500v-457h80v593H200Z"
          ></path>
        </svg>
      </div>
      <div>
        <h3 class="text-2xl font-headline text-white">Jornadas Intensivas</h3>
        <p class="text-white text-sm mt-2 font-body">
          Abordajes de 48-72hs para desestabilización aguda.
        </p>
      </div>
    </a>

    <article
      class="md:col-span-1 bg-tertiary-fixed-dim p-8 rounded-3xl flex flex-col justify-between group min-h-[180px] hover:shadow-lg transition-shadow"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 -960 960 960"
        fill="currentColor"
        class="text-on-tertiary-fixed"
        aria-hidden="true"
      >
        <path
          d="M120-160v-80h720v80H120Zm140-160-85-231 65-19 111 170 178-51-129-231 65-19 212 254 183-53q23-7 43.5 6.5T824-510q3 23-10.5 43.5T770-440L260-320Z"
        ></path>
      </svg>
      <h3 class="text-xl font-headline text-on-tertiary-fixed">
        Viajes Terapéuticos
      </h3>
    </article>

    <article
      class="md:col-span-1 bg-white p-8 rounded-3xl flex flex-col justify-between border border-outline-variant group min-h-[180px] hover:border-primary transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 -960 960 960"
        fill="currentColor"
        class="text-error"
        aria-hidden="true"
      >
        <path
          d="M440-440h-200v-80h200v-200h80v200h200v80h-200v200h-80v-200Zm40-360q67 0 126 25.5T708-706q43 43 68.5 102T802-478q0 121-66.5 220T560-111v-83q74-41 117-113.5T720-478q0-100-70-170t-170-70q-100 0-170 70t-70 170q0 98 43 170.5T400-194v83q-109-48-175.5-147T158-478q0-67 25.5-126t70.5-102q45-43 104-68.5T480-800Z"
        ></path>
      </svg>
      <h3 class="text-xl font-headline text-primary">Intervención en Crisis</h3>
    </article>
  </div>
</section>
