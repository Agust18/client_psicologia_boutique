---
import type { Profesional } from "./data/equipo";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

type Props = Omit<Profesional, "bullets"> & { foto: ImageMetadata };

const { id, nombre, titulo, foto, alt, bio, formacion, whatsapp, email } = Astro.props;
---

<div
  id={`modal-${id}`}
  class="modal-perfil fixed inset-0 z-50 flex items-center justify-center p-4 md:p-8 opacity-0 pointer-events-none transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`modal-nombre-${id}`}
>
  <!-- Backdrop -->
  <div
    class="absolute inset-0 bg-primary/70 backdrop-blur-sm"
    data-close
  ></div>

  <!-- Contenido -->
  <div
    class="modal-content relative bg-surface rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto"
  >
    <!-- Botón cerrar -->
    <button
      class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface hover:bg-surface-container-high transition-colors"
      aria-label="Cerrar"
      data-close
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 -960 960 960" fill="currentColor">
        <path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/>
      </svg>
    </button>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row gap-6 p-6 md:p-8 border-b border-outline-variant">
      <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl overflow-hidden flex-shrink-0 mx-auto sm:mx-0">
        <Image
          src={foto}
          alt={alt}
          width={128}
          height={128}
          class="w-full h-full object-cover object-top grayscale"
        />
      </div>
      <div class="text-center sm:text-left flex flex-col justify-center">
        <h3
          id={`modal-nombre-${id}`}
          class="font-headline text-2xl md:text-3xl text-primary"
        >
          {nombre}
        </h3>
        <p class="font-body text-xs uppercase tracking-widest text-secondary font-bold mt-2">
          {titulo}
        </p>
      </div>
    </div>

    <!-- Cuerpo -->
    <div class="p-6 md:p-8 space-y-6">

      <!-- Bio -->
      <p class="font-body text-on-surface leading-relaxed">{bio}</p>

      <!-- Formación -->
      {formacion.length > 0 && (
        <div>
          <h4 class="font-body text-xs uppercase tracking-widest text-secondary font-bold mb-3">
            Formación
          </h4>
          <ul class="space-y-2">
            {formacion.map((item) => (
              <li class="flex items-start gap-3 font-body text-sm text-on-surface">
                <span class="text-tertiary-fixed-dim mt-0.5 flex-shrink-0">—</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Contacto -->
      <div class="border-t border-outline-variant pt-6 flex flex-col sm:flex-row gap-3">
       <a
          href={`https://wa.me/${whatsapp}?text=Hola ${nombre.split(" ")[0]}, me comunico desde su sitio web.`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex items-center justify-center gap-2 bg-primary text-on-primary px-5 py-3 rounded-xl font-body text-sm font-semibold hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          WhatsApp
        </a>
        <a 
          href={`mailto:${email}?subject=Consulta desde el sitio web`}
          class="flex-1 flex items-center justify-center gap-2 border border-outline text-on-surface px-5 py-3 rounded-xl font-body text-sm font-semibold hover:bg-surface-container transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true">
            <path d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm320-280L160-640v400h640v-400L480-440Zm0-80 320-200H160l320 200ZM160-640v-80 480-400Z"/>
          </svg>
          Email
        </a>
      </div>

    </div>
  </div>
</div>

<style>
.modal-perfil.is-open {
  opacity: 1;
  pointer-events: auto;
}
.modal-content {
  transform: translateY(16px);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.modal-perfil.is-open .modal-content {
  transform: translateY(0);
}
</style>

<script define:vars={{ modalId: `modal-${id}` }}>
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.querySelectorAll('[data-close]').forEach(el => {
      el.addEventListener('click', () => {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
      }
    });
  }
</script>