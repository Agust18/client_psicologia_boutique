---
import { Image } from "astro:assets";
import type { Profesional } from "./data/equipo";
import type { ImageMetadata } from "astro";

interface Props {
  profesional: Profesional;
  foto: ImageMetadata;
}
const { profesional: p, foto } = Astro.props;
---

<div class="aspect-[3/4] overflow-hidden rounded-xl bg-surface-container-high relative mb-6 shadow-md cursor-pointer">
  <Image
    src={foto}
    alt={p.alt}
    width={500}
    height={667}
    class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 group-hover:blur-sm transition-all duration-700"
    loading="lazy"
    decoding="async"
  />
  <div class="absolute inset-0 bg-primary/80 backdrop-blur-xs flex flex-col justify-end p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 text-left">
    <ul class="space-y-3 text-white/90 text-sm font-body leading-relaxed translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
      {p.bullets.map((bullet) => (
        <li class="flex items-start gap-3">
          <span class="text-tertiary-fixed-dim mt-1 flex-shrink-0">—</span>
          {bullet}
        </li>
      ))}
    </ul>
  </div>
</div>