---
// ContactSection component - Single Responsibility: Contact/CTA display
const { id } = Astro.props;
---

<section id={id} class="py-24 md:py-32 px-8 bg-surface">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="font-headline text-4xl md:text-5xl text-primary mb-8 leading-tight">
      Comience su trayectoria hacia la <span class="italic text-secondary">excelencia clínica</span>.
    </h2>
    
    <p class="text-slate-700 text-lg md:text-xl mb-12 leading-relaxed">
      Estamos preparados para abordar los desafíos médicos y humanos más complejos. Agende una consulta inicial con nuestro equipo directivo.
    </p>

    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
      
      <a 
        href="https://wa.me/tu-numero" 
        class="inline-flex items-center justify-center bg-primary text-on-primary px-10 py-5 rounded-md text-lg font-bold shadow-lg hover:bg-primary-container transition-all min-h-[56px] w-full sm:w-auto text-center active:scale-95"
      >
        Solicitar Consulta Privada
      </a>

      <a 
        href="mailto:contacto@tuweb.com" 
        class="inline-flex items-center justify-center bg-white text-primary border-2 border-primary px-10 py-5 rounded-md text-lg font-bold hover:bg-surface-container-low transition-all min-h-[56px] w-full sm:w-auto text-center active:scale-95"
      >
        Contacto Corporativo
      </a>

    </div>
  </div>
</section>
<script>
  // Handle contact buttons
  const contactPrivateButton = document.querySelector('.contact-private-button');
  const contactCorporateButton = document.querySelector('.contact-corporate-button');

  if (contactPrivateButton) {
    contactPrivateButton.addEventListener('click', () => {
      alert('Para solicitar una consulta privada, por favor contacte directamente a nuestro equipo médico al email: consultas@ateliermedical.com o al teléfono: +54 11 1234-5678');
    });
  }

  if (contactCorporateButton) {
    contactCorporateButton.addEventListener('click', () => {
      alert('Para contacto corporativo u organizaciones, por favor contacte a nuestro departamento empresarial al email: corporativo@ateliermedical.com o al teléfono: +54 11 1234-5679');
    });
  }
</script>