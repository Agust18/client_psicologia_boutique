---

const { id } = Astro.props;
---

<section id={id} class="py-20 md:py-32 px-6 bg-primary text-white relative overflow-hidden mt-10">
  
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-[120px] -mr-48 -mt-48"></div>
  
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      
      <div class="lg:col-span-5 text-left">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-[1px] bg-tertiary-fixed-dim/40"></div>
          <span class="font-label text-[10px] uppercase tracking-[0.3em] text-tertiary-fixed-dim font-bold">
            Perfil de Atención
          </span>
        </div>
        <h2 class="font-headline text-5xl md:text-7xl leading-[1.1] mb-8">
          ¿A quién está <br /> 
          <span class="italic text-tertiary-fixed-dim font-light underline decoration-white/10 underline-offset-8">dirigido?</span>
        </h2>
      </div>

      <div class="lg:col-span-7">
        <p class="text-xl md:text-2xl text-white/90 font-body mb-12 leading-relaxed italic">
          A personas que atraviesan:
        </p>

        <div class="space-y-0 border-l border-white/10 ml-2">
          {[
            "Enfermedades médicas complejas",
            "Internaciones prolongadas",
            "Deterioro funcional o cognitivo",
            "Síntomas psiquiátricos asociados a enfermedad médica",
            "Situaciones donde el abordaje resulta fragmentado o insuficiente"
          ].map((item) => (
            <div class="group relative pl-8 pb-10 last:pb-0">
              <div class="absolute left-[-4.5px] top-2 w-2 h-2 rounded-full bg-tertiary-fixed-dim ring-4 ring-primary group-hover:scale-150 transition-transform duration-300 shadow-[0_0_15px_rgba(219,190,138,0.5)]"></div>
              
              <p class="text-lg md:text-xl text-white/70 font-body leading-snug group-hover:text-white transition-colors duration-300">
                {item}
              </p>
            </div>
          ))}
        </div>

        <div class="mt-16 p-8 md:p-12 rounded-[2.5rem] bg-white/5 border border-white/10 relative overflow-hidden group/card hover:bg-white/[0.08] transition-colors duration-500">
          <p class="text-white/90 text-xl md:text-2xl leading-relaxed font-body relative z-10">
            Y a <strong class="text-tertiary-fixed-dim font-bold">familias</strong> que necesitan orientación, contención y claridad en la toma de decisiones.
          </p>
          
          <div class="absolute bottom-0 right-0 p-6 opacity-20 group-hover/card:opacity-50 transition-opacity">
            <div class="w-16 h-16 border-r border-b border-tertiary-fixed-dim rounded-br-[2rem]"></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>