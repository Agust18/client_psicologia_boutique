---
import { Image } from 'astro:assets';
import aboutImg from "../assets/images/about.jpg";
// AboutSection component - Single Responsibility: About display
const { id } = Astro.props;
---

<section id={id} class="py-24 md:py-32 px-8 bg-surface scroll-reveal">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-5 relative animate-on-scroll">
        <div class="aspect-[4/5] rounded-xl overflow-hidden shadow-2xl transform hover:scale-105 transition-transform duration-500">
          <Image
            src={aboutImg}
            alt="Medical Consultation"
            class="w-full h-full object-cover"
            loading="lazy"
            height={1000}  
            format="webp"
            quality={80}
            width={800}    
          />
        </div>
        <div class="absolute -bottom-10 -right-10 bg-white p-8 rounded-lg shadow-xl max-w-xs hidden md:block animate-on-scroll animation-delay-300 hover:shadow-2xl transition-shadow duration-300">
          <p class="font-headline italic text-2xl text-primary">"La subjetividad como dato objetivo."</p>
        </div>
      </div>
      <div class="lg:col-span-7 animate-on-scroll animation-delay-200">
        <span class="font-label text-sm uppercase tracking-widest text-secondary font-bold block mb-4">Sobre Nosotros</span>
        <h2 class="font-headline text-4xl md:text-5xl text-primary leading-tight mb-8">Abordaje Integral y Sistémico</h2>
        <div class="space-y-6 text-on-surface-variant text-lg leading-relaxed">
          <p>Somos un equipo orientado al abordaje integral del paciente crítico, operando bajo una filosofía que trasciende la medicina tradicional fragmentada.</p>
          <p class="font-medium text-primary">Consideramos al individuo como un sistema dinámico y a la familia como una organización viva que requiere intervención coordinada y estratégica.</p>
          <p>Nuestro modelo no es una plantilla predefinida; es un proceso de co-construcción donde cada trayectoria terapéutica se diseña a medida de la realidad clínica y emocional del consultante.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: translateY(50px);
    transition: all 0.8s ease-out;
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease-out;
  }

  .animate-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .animation-delay-200 {
    transition-delay: 0.2s;
  }

  .animation-delay-300 {
    transition-delay: 0.3s;
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
      }
    });
  }, observerOptions);

  // Observe all scroll-reveal elements
  document.querySelectorAll('.scroll-reveal, .animate-on-scroll').forEach(el => {
    observer.observe(el);
  });

  
</script>

