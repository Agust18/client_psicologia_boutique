---
/* Navbar.astro - Atelier Medical */
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 w-full z-50 h-20 md:h-24 flex items-center transition-colors duration-500 border-b border-transparent bg-transparent"
>
  <div class="max-w-7xl mx-auto px-4 md:px-6 w-full h-full flex justify-between items-center">
    <div class="z-50">
      <a
        href="#inicio"
        class="font-headline font-bold text-lg md:text-xl text-white hover:text-tertiary-fixed-dim transition-colors"
      >
        Consultorio Medical
      </a>
    </div>

    <div class="hidden md:flex items-center gap-6 h-full">
      <a class="nav-link text-white/90 hover:text-tertiary-fixed-dim text-sm font-medium transition-colors px-2" href="#inicio">Inicio</a>
      <a class="nav-link text-white/90 hover:text-tertiary-fixed-dim text-sm font-medium transition-colors px-2" href="#sobre-nosotros">Sobre Nosotros</a>
      <a class="nav-link text-white/90 hover:text-tertiary-fixed-dim text-sm font-medium transition-colors px-2" href="#equipo-medico">Equipo Médico</a>
      <a class="nav-link text-white/90 hover:text-tertiary-fixed-dim text-sm font-medium transition-colors px-2" href="#filosofia">Filosofía</a>
      <a class="nav-link text-white/90 hover:text-tertiary-fixed-dim text-sm font-medium transition-colors px-2" href="#areas-intervencion">Servicios</a>
      <a class="nav-link text-white/90 hover:text-tertiary-fixed-dim text-sm font-medium transition-colors px-2" href="#psicologia-organizacional">Organizaciones</a>

      <a
        href="#contacto"
        class="inline-block bg-tertiary-fixed-dim text-on-tertiary-fixed px-8 py-4 rounded-md font-bold hover:bg-white hover:text-primary transition-all duration-300 transform hover:scale-105 shadow-lg text-center min-h-[48px]"
      >
        Solicitar Consulta
      </a>
    </div>

    <button
      id="mobile-menu-button"
      aria-label="Abrir menú"
      class="md:hidden z-50 flex flex-col justify-center items-center w-10 h-10 gap-1.5 focus:outline-none"
    >
      <span class="line w-6 h-0.5 bg-white transition-all duration-300"></span>
      <span class="line w-6 h-0.5 bg-white transition-all duration-300"></span>
      <span class="line w-6 h-0.5 bg-white transition-all duration-300"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 w-full h-screen bg-primary/98 backdrop-blur-xl flex flex-col items-center justify-center translate-x-full transition-transform duration-500 md:hidden z-40"
  >
    <div class="flex flex-col items-center gap-4 w-full max-w-xs px-6">
      <a class="text-white text-xl font-headline py-3 w-full text-center" href="#inicio">Inicio</a>
      <a class="text-white text-xl font-headline py-3 w-full text-center" href="#sobre-nosotros">Sobre Nosotros</a>
      <a class="text-white text-xl font-headline py-3 w-full text-center" href="#equipo-medico">Equipo Médico</a>
      <a class="text-white text-xl font-headline py-3 w-full text-center" href="#filosofia">Filosofía</a>
      <a class="text-white text-xl font-headline py-3 w-full text-center" href="#areas-intervencion">Servicios</a>
      <a class="text-white text-xl font-headline py-3 w-full text-center" href="#psicologia-organizacional">Organizaciones</a>

      <a
        href="#contacto"
        class="inline-block bg-tertiary-fixed-dim text-on-tertiary-fixed px-10 py-5 rounded-md font-bold w-full text-center min-h-[48px]"
      >
        Solicitar Consulta
      </a>
    </div>
  </div>
</nav>

<style>
  /* Alturas fijas para evitar el salto (Cumulative Layout Shift) */
  #main-nav {
    height: 80px; /* Corresponde a h-20 */
  }

  @media (min-width: 768px) {
    #main-nav {
      height: 96px; /* Corresponde a h-24 */
    }
  }

  /* Estado al scrollear */
  .nav-scrolled {
    background-color: #001237 !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    border-bottom-color: rgba(255, 255, 255, 0.1);
    /* Forzamos que la altura no cambie ni un píxel */
    height: 80px !important;
  }

  @media (min-width: 768px) {
    .nav-scrolled {
      height: 96px !important;
    }
  }

  /* Animación Hamburguesa */
  #mobile-menu-button.open .line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #mobile-menu-button.open .line:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-button.open .line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  #mobile-menu.active {
    transform: translateX(0);
  }

  /* Fixes adicionales */
  @media (max-width: 768px) {
    #main-nav {
      width: 100%;
      left: 0;
    }
  }
</style>

<script>
  const setupNav = () => {
    const nav = document.getElementById("main-nav");
    const btn = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    const updateNavState = () => {
      // Usamos 20px de margen para que el cambio sea casi inmediato al bajar
      if (window.scrollY > 20) {
        nav?.classList.add("nav-scrolled");
      } else {
        nav?.classList.remove("nav-scrolled");
      }
    };

    // Scroll listener optimizado
    window.addEventListener("scroll", updateNavState, { passive: true });
    
    // Ejecución inmediata por si carga con scroll
    updateNavState();

    // Mobile Menu Toggle
    btn?.addEventListener("click", () => {
      const isOpen = menu?.classList.toggle("active");
      btn.classList.toggle("open");
      
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      document.body.style.overflow = isOpen ? "hidden" : "";
    });

    // Cerrar al clickear links
    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        btn?.classList.remove("open");
        menu?.classList.remove("active");
        document.body.style.overflow = "";
      });
    });
  };

  // Inicialización compatible con Astro
  document.addEventListener("DOMContentLoaded", setupNav);
</script>